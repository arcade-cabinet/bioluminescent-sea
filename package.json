{
  "name": "bioluminescent-sea",
  "private": true,
  "version": "0.13.0",
  "description": "Meditative bioluminescent-trace explorer — sink into an abyssal sea, trace glowing routes past landmark anemones, surface breathing easier than when you started.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "content:compile": "node scripts/compile-content.mjs",
    "icons:android": "node scripts/svg-to-mipmaps.mjs",
    "sim:sweep": "TSX_TSCONFIG_PATH=./tsconfig.app.json tsx scripts/sim-sweep.ts",
    "predev": "pnpm run content:compile",
    "prebuild": "pnpm run content:compile",
    "pretypecheck": "pnpm run content:compile",
    "pretest:node": "pnpm run content:compile",
    "pretest:dom": "pnpm run content:compile",
    "pretest:browser": "pnpm run content:compile",
    "pretest:e2e": "pnpm run content:compile && pnpm exec vite build --mode development",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome lint .",
    "check:format": "biome format .",
    "test": "pnpm run test:node && pnpm run test:dom",
    "test:node": "vitest run --config vitest.config.ts",
    "test:dom": "vitest run --config vitest.dom.config.ts",
    "test:browser": "vitest --config vitest.browser.config.ts --browser --run",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/cormorant-garamond": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "lucide-react": "^1.11.0",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.18.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "seedrandom": "^3.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tone": "^15.1.22",
    "yuka": "^0.7.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@capacitor/cli": "^8.3.0",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/spectral": "^5.2.8",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/seedrandom": "^3.0.8",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
